{
  "dataset": {
    "repo_id": "local/so101_pick_lift_cube_cropped_resized",
    "root": "data/so101_pick_lift_cube_cropped_resized"
  },
  "env": {
    "type": "gym_manipulator",
    "name": "so101_real_robot",
    "fps": 30,
    "robot": {
      "type": "so101_follower",
      "port": "/dev/ttyACM0",
      "use_degrees": true,
      "disable_torque_on_disconnect": true,
      "cameras": {
        "front": {
          "type": "opencv",
          "index_or_path": 0,
          "height": 480,
          "width": 640,
          "fps": 30
        },
        "wrist": {
          "type": "opencv",
          "index_or_path": 2,
          "height": 480,
          "width": 640,
          "fps": 30
        }
      }
    },
    "teleop": {
      "type": "gamepad",
      "use_gripper": true
    },
    "processor": {
      "control_mode": "gamepad",
      "observation": {
        "add_joint_velocity_to_observation": true,
        "add_current_to_observation": true,
        "add_ee_pose_to_observation": true,
        "display_cameras": false
      },
      "image_preprocessing": {
        "crop_params_dict": {},
        "resize_size": [128, 128]
      },
      "gripper": {
        "use_gripper": true,
        "gripper_penalty": -0.02
      },
      "reset": {
        "fixed_reset_joint_positions": [0.0, 0.0, 0.0, 90.0, 0.0, 5.0],
        "reset_time_s": 2.5,
        "control_time_s": 20.0,
        "terminate_on_success": true
      },
      "inverse_kinematics": {
        "urdf_path": "assets/so101/so101_new_calib.urdf",
        "target_frame_name": "gripper_frame_link",
        "end_effector_bounds": {
          "min": [-1.0, -1.0, -1.0],
          "max": [1.0, 1.0, 1.0]
        },
        "end_effector_step_sizes": {
          "x": 0.025,
          "y": 0.025,
          "z": 0.025
        }
      },
      "reward_classifier": {
        "pretrained_path": null,
        "success_threshold": 0.7,
        "success_reward": 1.0
      },
      "max_gripper_pos": 100.0
    }
  },
  "policy": {
    "type": "sac",
    "device": "cuda",
    "storage_device": "cpu",
    "vision_encoder_name": "helper2424/resnet10",
    "freeze_vision_encoder": true,
    "shared_encoder": true,
    "image_encoder_hidden_dim": 32,
    "image_embedding_pooling_dim": 8,
    "num_discrete_actions": 3,
    "input_features": {
      "observation.images.front": {
        "type": "VISUAL",
        "shape": [3, 128, 128]
      },
      "observation.images.wrist": {
        "type": "VISUAL",
        "shape": [3, 128, 128]
      },
      "observation.state": {
        "type": "STATE",
        "shape": [18]
      }
    },
    "output_features": {
      "action": {
        "type": "ACTION",
        "shape": [3]
      }
    },
    "online_steps": 1000000,
    "online_buffer_capacity": 50000,
    "offline_buffer_capacity": 10000,
    "online_step_before_learning": 100,
    "policy_update_freq": 1,
    "discount": 0.99,
    "temperature_init": 0.01,
    "num_critics": 2,
    "critic_lr": 3e-4,
    "actor_lr": 3e-4,
    "temperature_lr": 3e-4,
    "critic_target_update_weight": 0.005,
    "utd_ratio": 1,
    "use_backup_entropy": true,
    "grad_clip_norm": 40.0,
    "actor_learner_config": {
      "learner_host": "127.0.0.1",
      "learner_port": 50051,
      "policy_parameters_push_frequency": 4,
      "queue_get_timeout": 2
    },
    "concurrency": {
      "actor": "threads",
      "learner": "threads"
    },
    "use_torch_compile": false
  },
  "output_dir": "outputs/train/so101_hilserl",
  "job_name": "so101-hilserl",
  "seed": 1000,
  "num_workers": 4,
  "batch_size": 256,
  "steps": 100000,
  "save_freq": 10000,
  "log_freq": 200,
  "save_checkpoint": true,
  "wandb": {
    "enable": false,
    "project": "so101-hilserl",
    "disable_artifact": false
  }
}
