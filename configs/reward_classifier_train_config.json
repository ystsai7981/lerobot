{
  "dataset": {
    "repo_id": "local/so101_reward_data",
    "root": "data/so101_reward_data"
  },
  "reward_model": {
    "type": "reward_classifier",
    "model_name": "helper2424/resnet10",
    "model_type": "cnn",
    "num_cameras": 2,
    "num_classes": 2,
    "hidden_dim": 256,
    "dropout_rate": 0.1,
    "learning_rate": 1e-4,
    "device": "cuda",
    "input_features": {
      "observation.images.front": {
        "type": "VISUAL",
        "shape": [3, 128, 128]
      },
      "observation.images.wrist": {
        "type": "VISUAL",
        "shape": [3, 128, 128]
      }
    },
    "push_to_hub": false,
    "repo_id": null
  },
  "output_dir": "outputs/train/so101_reward_classifier",
  "job_name": "so101-reward-classifier",
  "batch_size": 16,
  "num_workers": 4,
  "steps": 5000,
  "log_freq": 10,
  "eval_freq": 1000,
  "save_freq": 1000,
  "save_checkpoint": true,
  "seed": 2,
  "resume": false,
  "wandb": {
    "enable": false,
    "project": "so101-reward-classifier",
    "disable_artifact": false
  }
}
