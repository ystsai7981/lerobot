{
  "env": {
    "name": "so101_real_robot",
    "robot": {
      "type": "so101_follower",
      "port": "/dev/ttyACM0",
      "use_degrees": true,
      "disable_torque_on_disconnect": true,
      "cameras": {
        "front": {
          "type": "opencv",
          "index_or_path": 0,
          "height": 480,
          "width": 640,
          "fps": 30
        },
        "wrist": {
          "type": "opencv",
          "index_or_path": 2,
          "height": 480,
          "width": 640,
          "fps": 30
        }
      }
    },
    "teleop": {
      "type": "so101_leader_hil",
      "port": "/dev/ttyACM1",
      "use_degrees": true,
      "use_gripper": true,
      "urdf_path": "assets/so101/so101_new_calib.urdf",
      "target_frame_name": "gripper_frame_link",
      "end_effector_step_sizes": {"x": 0.025, "y": 0.025, "z": 0.025},
      "gripper_open_threshold_deg": 1.0,
      "gripper_close_threshold_deg": -1.0
    },
    "processor": {
      "control_mode": "leader_hil",
      "observation": {
        "add_joint_velocity_to_observation": true,
        "add_current_to_observation": true,
        "add_ee_pose_to_observation": true,
        "display_cameras": false
      },
      "image_preprocessing": {
        "crop_params_dict": {},
        "resize_size": [128, 128]
      },
      "gripper": {
        "use_gripper": true,
        "gripper_penalty": -0.02
      },
      "reset": {
        "fixed_reset_joint_positions": [0.0, 0.0, 0.0, 90.0, 0.0, 5.0],
        "reset_time_s": 2.5,
        "control_time_s": 20.0,
        "terminate_on_success": true
      },
      "inverse_kinematics": {
        "urdf_path": "assets/so101/so101_new_calib.urdf",
        "target_frame_name": "gripper_frame_link",
        "end_effector_bounds": {
          "min": [-1.0, -1.0, -1.0],
          "max": [1.0, 1.0, 1.0]
        },
        "end_effector_step_sizes": {
          "x": 0.025,
          "y": 0.025,
          "z": 0.025
        }
      },
      "max_gripper_pos": 100.0
    }
  },
  "dataset": {
    "repo_id": "local/so101_pick_lift_cube",
    "task": "pick_and_lift",
    "root": "data/so101_pick_lift_cube",
    "num_episodes_to_record": 15,
    "replay_episode": null,
    "push_to_hub": false
  },
  "mode": "record",
  "device": "cpu"
}
